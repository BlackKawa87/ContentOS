// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../server/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  OWNER
  ADMIN
  USER
}

enum Language {
  EN
  PT
  ES
}

enum Theme {
  LIGHT
  DARK
}

enum ProjectType {
  STUDY
  REVERSE_ENGINEERING
  CONTENT_BUILDER
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

enum VideoSourceType {
  YOUTUBE_VIDEO
  YOUTUBE_PLAYLIST
  MP4
  MP3
}

enum VideoStatus {
  NOT_IMPORTED
  READY
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum JobPipeline {
  STUDY
  REVERSE_CHANNEL_IMPORT
  VIDEO_ANALYSIS
}

enum JobStage {
  QUEUED
  DOWNLOADED
  EXTRACTED
  TRANSCRIBED
  TRANSLATED
  NARRATED
  SLIDES_GENERATED
  VIDEO_RENDERED
  QUIZ_GENERATED
  FLASHCARDS_GENERATED
  EXPORTED
  CHANNEL_METADATA_FETCHED
  VIDEOS_LISTED
  VIDEOS_METADATA_FETCHED
  STATS_CALCULATED
  VIDEO_SELECTED
  VIDEO_DOWNLOADED
  AUDIO_EXTRACTED
  TIMELINE_SEGMENTED
  NARRATIVE_ANALYZED
  VISUAL_ANALYZED
  AUDIO_ANALYZED
  READY_FOR_VIRAL_DNA
  COMPLETED
  FAILED
}

enum TimelineSegmentType {
  HOOK
  SETUP
  CONTEXT
  PROBLEM
  OPEN_LOOP
  ESCALATION
  EVIDENCE
  STORY_DEVELOPMENT
  TRANSITION
  PATTERN_INTERRUPT
  REVEAL
  PAYOFF
  SUMMARY
  CTA
  OUTRO
}

enum HookType {
  UNEXPECTED_FACT
  QUESTION
  CONTRARIAN
  MYSTERY
  STORY_OPENING
  AUTHORITY
  PROBLEM_FIRST
  FUTURE_PROMISE
  EMOTIONAL
}

enum NarrativePattern {
  DOCUMENTARY
  MYSTERY_REVEAL
  CHRONOLOGICAL
  EDUCATIONAL
  TRANSFORMATION
  INVESTIGATION
  CONFLICT
  BIOGRAPHY
  TIMELINE
}

enum VisualSceneCategory {
  ARCHIVAL_PHOTO
  PORTRAIT
  LANDSCAPE
  MAP
  DOCUMENT
  CHART
  SCREENSHOT
  ILLUSTRATION
  GENERATED_IMAGE
  TEXT_CARD
  UNKNOWN
}

enum VisualSceneMotion {
  SLOW_ZOOM
  ZOOM_OUT
  PAN
  STATIC
  CROP
  UNKNOWN
}

enum JobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

enum ChannelStatus {
  PENDING
  IMPORTING
  READY
  FAILED
}

enum OutlierClass {
  NORMAL
  ABOVE_AVERAGE
  STRONG_OUTLIER
  VIRAL_OUTLIER
}

enum ApiProvider {
  OPENAI
  ELEVENLABS
}

enum StorageBucket {
  VIDEOS
  AUDIO
  SLIDES
  EXPORTS
  IMAGES
  DOCUMENTS
  GENERATED
  THUMBNAILS
}

enum ContentBuilderChannel {
  YOUTUBE
  SHORTS
  TIKTOK
  INSTAGRAM
  BLOG
  NEWSLETTER
  PODCAST
  SLIDES
  COURSE
}

// ---------------------------------------------------------------------------
// Core / Auth
// ---------------------------------------------------------------------------

/// Mirrors a row in Supabase `auth.users`; id is the same UUID as auth.users.id.
model Profile {
  id              String   @id @db.Uuid
  email           String   @unique
  displayName     String?
  role            Role     @default(USER)
  defaultLanguage Language @default(EN)
  translationLang Language @default(PT)
  defaultVoiceId  String?
  theme           Theme    @default(LIGHT)

  openaiApiKeyEnc     Bytes?
  elevenlabsApiKeyEnc Bytes?

  reverseDefaultImportLimit Int   @default(25)
  reverseMaxVideos          Int   @default(100)
  reverseMaxPlaylists       Int   @default(10)
  outlierAboveAvgMultiplier Float @default(2)
  outlierStrongMultiplier   Float @default(5)
  outlierViralMultiplier    Float @default(10)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  projects       Project[]
  processingJobs ProcessingJob[] @relation("JobRetriedBy")
  apiUsageLogs   ApiUsageLog[]
  auditLogs      AuditLog[]

  @@index([role])
  @@map("profiles")
}

// ---------------------------------------------------------------------------
// Projects / Videos
// ---------------------------------------------------------------------------

model Project {
  id      String        @id @default(uuid()) @db.Uuid
  owner   Profile       @relation(fields: [ownerId], references: [id])
  ownerId String        @db.Uuid
  title   String
  type    ProjectType
  status  ProjectStatus @default(ACTIVE)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  videos                Video[]
  channels              Channel[]
  channelAnalyses       ChannelAnalysis[]
  contentBuilderOutputs ContentBuilderOutput[]
  knowledgeBaseEntries  KnowledgeBaseEntry[]
  apiUsageLogs          ApiUsageLog[]
  storageAssets         StorageAsset[]

  @@index([ownerId])
  @@index([status])
  @@map("projects")
}

model Video {
  id          String          @id @default(uuid()) @db.Uuid
  project     Project         @relation(fields: [projectId], references: [id])
  projectId   String          @db.Uuid
  sourceUrl   String
  sourceType  VideoSourceType
  title       String?
  durationSec Int?
  status      VideoStatus     @default(QUEUED)

  // Reverse Engineering Engine: channel-imported video metadata (all optional — unused by Study Engine)
  channel        Channel?  @relation(fields: [channelId], references: [id])
  channelId      String?   @db.Uuid
  playlist       Playlist? @relation(fields: [playlistId], references: [id])
  playlistId     String?   @db.Uuid
  youtubeVideoId String?
  thumbnailUrl   String?
  publishedAt    DateTime?
  language       String?
  tags           Json?
  chapters       Json?

  views        Int?
  likes        Int?
  comments     Int?
  viewsPerDay  Float?
  viewsPerHour Float?
  ageInDays    Int?

  outlierScore Float?
  outlierClass OutlierClass?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  processingJobs  ProcessingJob[]
  transcript      Transcript?
  translation     Translation?
  narrationAsset  NarrationAsset?
  slideDeck       SlideDeck?
  studyVideoAsset StudyVideoAsset?
  glossary        Glossary?
  quiz            Quiz?
  flashcards      Flashcard[]
  channelAnalysis ChannelAnalysis?
  storageAssets   StorageAsset[]
  apiUsageLogs    ApiUsageLog[]

  videoAnalysis     VideoAnalysis?
  videoTranscript   VideoTranscript?
  timelineSegments  TimelineSegment[]
  narrativeAnalysis NarrativeAnalysis?
  visualScenes      VisualScene[]
  audioMetric       AudioMetric?

  @@index([projectId])
  @@index([status])
  @@index([channelId])
  @@index([playlistId])
  @@index([youtubeVideoId])
  @@map("videos")
}

// ---------------------------------------------------------------------------
// Reverse Engineering Engine: Channel Importer (Phase 1)
// ---------------------------------------------------------------------------

model Channel {
  id        String  @id @default(uuid()) @db.Uuid
  project   Project @relation(fields: [projectId], references: [id])
  projectId String  @db.Uuid

  sourceUrl        String
  youtubeChannelId String?
  handle           String?
  title            String?
  description      String?
  thumbnailUrl     String?
  bannerUrl        String?
  language         String?
  country          String?
  status           ChannelStatus @default(PENDING)

  createdAt  DateTime  @default(now())
  importedAt DateTime?
  lastSyncAt DateTime?
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  playlists      Playlist[]
  videos         Video[]
  processingJobs ProcessingJob[]

  @@index([projectId])
  @@map("channels")
}

model Playlist {
  id        String  @id @default(uuid()) @db.Uuid
  channel   Channel @relation(fields: [channelId], references: [id])
  channelId String  @db.Uuid

  youtubePlaylistId String
  title             String?
  description       String?
  thumbnailUrl      String?
  videoCount        Int?

  createdAt  DateTime  @default(now())
  importedAt DateTime?

  videos Video[]

  @@index([channelId])
  @@map("playlists")
}

// ---------------------------------------------------------------------------
// Processing queue
// ---------------------------------------------------------------------------

model ProcessingJob {
  id          String      @id @default(uuid()) @db.Uuid
  pipeline    JobPipeline @default(STUDY)
  video       Video?      @relation(fields: [videoId], references: [id])
  videoId     String?     @db.Uuid
  channel     Channel?    @relation(fields: [channelId], references: [id])
  channelId   String?     @db.Uuid
  stage       JobStage    @default(QUEUED)
  status      JobStatus   @default(PENDING)
  attempts    Int         @default(0)
  maxAttempts Int         @default(3)
  lastError   String?
  retriedBy   Profile?    @relation("JobRetriedBy", fields: [retriedById], references: [id])
  retriedById String?     @db.Uuid

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([videoId])
  @@index([channelId])
  @@index([stage, status])
  @@map("processing_jobs")
}

// ---------------------------------------------------------------------------
// Study Engine artifacts
// ---------------------------------------------------------------------------

model Transcript {
  id          String   @id @default(uuid()) @db.Uuid
  video       Video    @relation(fields: [videoId], references: [id])
  videoId     String   @unique @db.Uuid
  language    Language @default(EN)
  content     String
  storagePath String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("transcripts")
}

model Translation {
  id          String   @id @default(uuid()) @db.Uuid
  video       Video    @relation(fields: [videoId], references: [id])
  videoId     String   @unique @db.Uuid
  language    Language @default(PT)
  content     String
  storagePath String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("translations")
}

model NarrationAsset {
  id          String   @id @default(uuid()) @db.Uuid
  video       Video    @relation(fields: [videoId], references: [id])
  videoId     String   @unique @db.Uuid
  voiceId     String
  language    Language @default(PT)
  script      String
  storagePath String
  durationSec Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("narration_assets")
}

model SlideDeck {
  id         String  @id @default(uuid()) @db.Uuid
  video      Video   @relation(fields: [videoId], references: [id])
  videoId    String  @unique @db.Uuid
  slideCount Int
  pptxPath   String
  pdfPath    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("slide_decks")
}

model StudyVideoAsset {
  id          String @id @default(uuid()) @db.Uuid
  video       Video  @relation(fields: [videoId], references: [id])
  videoId     String @unique @db.Uuid
  storagePath String
  durationSec Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("study_video_assets")
}

model Glossary {
  id      String @id @default(uuid()) @db.Uuid
  video   Video  @relation(fields: [videoId], references: [id])
  videoId String @unique @db.Uuid
  terms   Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("glossaries")
}

model Quiz {
  id      String @id @default(uuid()) @db.Uuid
  video   Video  @relation(fields: [videoId], references: [id])
  videoId String @unique @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questions QuizQuestion[]

  @@map("quizzes")
}

model QuizQuestion {
  id            String  @id @default(uuid()) @db.Uuid
  quiz          Quiz    @relation(fields: [quizId], references: [id])
  quizId        String  @db.Uuid
  question      String
  options       Json
  correctOption Int
  explanation   String?
  order         Int     @default(0)

  createdAt DateTime @default(now())

  @@index([quizId])
  @@map("quiz_questions")
}

model Flashcard {
  id      String @id @default(uuid()) @db.Uuid
  video   Video  @relation(fields: [videoId], references: [id])
  videoId String @db.Uuid
  front   String
  back    String
  order   Int    @default(0)

  createdAt DateTime @default(now())

  @@index([videoId])
  @@map("flashcards")
}

// ---------------------------------------------------------------------------
// Reverse Engineering Engine (schema only for now)
// ---------------------------------------------------------------------------

model ChannelAnalysis {
  id        String  @id @default(uuid()) @db.Uuid
  project   Project @relation(fields: [projectId], references: [id])
  projectId String  @db.Uuid
  video     Video?  @relation(fields: [videoId], references: [id])
  videoId   String? @unique @db.Uuid

  sourceUrl String

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  viralDnaProfile ViralDnaProfile?

  @@index([projectId])
  @@map("channel_analyses")
}

model ViralDnaProfile {
  id                String          @id @default(uuid()) @db.Uuid
  channelAnalysis   ChannelAnalysis @relation(fields: [channelAnalysisId], references: [id])
  channelAnalysisId String          @unique @db.Uuid

  hookDurationSec     Float?
  avgSceneDurationSec Float?
  voiceSpeedWpm       Float?
  imageCount          Int?
  emotionalCurve      Json?
  ctaStyle            String?
  visualRhythm        Json?
  narrativePattern    String?
  retentionPattern    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("viral_dna_profiles")
}

// ---------------------------------------------------------------------------
// Video Reverse Engineering Engine (Phase 2): per-video analysis
// ---------------------------------------------------------------------------

/// Module 1 (download) + overall progress marker for the analysis pipeline.
/// Errors/attempts/timestamps live on ProcessingJob (reused) — not duplicated here.
model VideoAnalysis {
  id      String @id @default(uuid()) @db.Uuid
  video   Video  @relation(fields: [videoId], references: [id])
  videoId String @unique @db.Uuid

  videoStoragePath     String?
  audioStoragePath     String?
  thumbnailStoragePath String?
  subtitlesStoragePath String?
  fileSizeBytes        Int?
  downloadDurationMs   Int?
  downloadFormat       String?
  audioDurationMs      Int?

  readyForViralDnaAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("video_analyses")
}

/// Module 2: transcription.
model VideoTranscript {
  id      String @id @default(uuid()) @db.Uuid
  video   Video  @relation(fields: [videoId], references: [id])
  videoId String @unique @db.Uuid

  rawText          String
  reviewedText     String?
  language         String?
  model            String?
  inputTokens      Int?
  outputTokens     Int?
  audioMinutes     Float?
  estimatedCostUsd Float?
  wordsPerMinute   Float?
  confidence       Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  segments TranscriptSegment[]

  @@map("video_transcripts")
}

model TranscriptSegment {
  id           String          @id @default(uuid()) @db.Uuid
  transcript   VideoTranscript @relation(fields: [transcriptId], references: [id])
  transcriptId String          @db.Uuid
  index        Int
  startSec     Float
  endSec       Float
  text         String
  confidence   Float?

  @@index([transcriptId])
  @@map("transcript_segments")
}

/// Module 3: timeline segmentation into narrative blocks. User-editable.
model TimelineSegment {
  id          String              @id @default(uuid()) @db.Uuid
  video       Video               @relation(fields: [videoId], references: [id])
  videoId     String              @db.Uuid
  index       Int
  type        TimelineSegmentType
  startSec    Float
  endSec      Float
  durationSec Float
  text        String
  purpose     String?
  emotion     String?
  intensity   Float?
  confidence  Float?
  evidence    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([videoId])
  @@map("timeline_segments")
}

/// Module 4: narrative analysis conclusions, each backed by evidence text.
model NarrativeAnalysis {
  id      String @id @default(uuid()) @db.Uuid
  video   Video  @relation(fields: [videoId], references: [id])
  videoId String @unique @db.Uuid

  hookType            HookType?
  hookDurationSec     Float?
  promise             String?
  openLoopCount       Int?
  payoffCount         Int?
  revealFrequency     Float?
  storyStructure      String?
  informationDensity  Float?
  curiosityScore      Float?
  narrativeStyle      String?
  narrativePattern    NarrativePattern?
  retentionMechanisms String?
  evidence            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("narrative_analyses")
}

/// Module 5: visual analysis — one row per detected scene.
model VisualScene {
  id               String              @id @default(uuid()) @db.Uuid
  video            Video               @relation(fields: [videoId], references: [id])
  videoId          String              @db.Uuid
  index            Int
  startSec         Float
  endSec           Float
  durationSec      Float
  frameStoragePath String?
  category         VisualSceneCategory
  motion           VisualSceneMotion
  transition       String?
  sceneScore       Float?
  description      String?
  confidence       Float?

  createdAt DateTime @default(now())

  @@index([videoId])
  @@map("visual_scenes")
}

/// Module 6: deterministic audio metrics (no AI). energyCurve is the one
/// justified time-series JSON field — modeling per-sample rows would be
/// impractical for what's purely chart-rendering data.
model AudioMetric {
  id      String @id @default(uuid()) @db.Uuid
  video   Video  @relation(fields: [videoId], references: [id])
  videoId String @unique @db.Uuid

  wordsPerMinute      Float?
  averagePaceWpm      Float?
  medianPaceWpm       Float?
  pauseCount          Int?
  avgPauseDurationSec Float?
  speechDensity       Float?
  energyCurve         Json?
  volumeVariation     Float?
  silenceRatio        Float?
  narrationSpeed      Float?
  sceneSyncScore      Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("audio_metrics")
}

// ---------------------------------------------------------------------------
// Content Builder (schema only for now)
// ---------------------------------------------------------------------------

model ContentBuilderOutput {
  id        String                @id @default(uuid()) @db.Uuid
  project   Project               @relation(fields: [projectId], references: [id])
  projectId String                @db.Uuid
  channel   ContentBuilderChannel
  title     String
  content   Json
  status    ProjectStatus         @default(ACTIVE)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([projectId])
  @@map("content_builder_outputs")
}

// ---------------------------------------------------------------------------
// Knowledge Base
// ---------------------------------------------------------------------------

model KnowledgeBaseEntry {
  id        String  @id @default(uuid()) @db.Uuid
  project   Project @relation(fields: [projectId], references: [id])
  projectId String  @db.Uuid
  title     String
  entryType String
  summary   String?
  refTable  String
  refId     String  @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([refTable, refId])
  @@map("knowledge_base_entries")
}

// ---------------------------------------------------------------------------
// Observability / Cost
// ---------------------------------------------------------------------------

model ApiUsageLog {
  id        String   @id @default(uuid()) @db.Uuid
  profile   Profile  @relation(fields: [profileId], references: [id])
  profileId String   @db.Uuid
  project   Project? @relation(fields: [projectId], references: [id])
  projectId String?  @db.Uuid
  video     Video?   @relation(fields: [videoId], references: [id])
  videoId   String?  @db.Uuid

  provider         ApiProvider
  unit             String
  quantity         Float
  estimatedCostUsd Float

  createdAt DateTime @default(now())

  @@index([profileId])
  @@index([projectId])
  @@index([videoId])
  @@map("api_usage_logs")
}

model AuditLog {
  id       String   @id @default(uuid()) @db.Uuid
  actor    Profile? @relation(fields: [actorId], references: [id])
  actorId  String?  @db.Uuid
  action   String
  entity   String
  entityId String?  @db.Uuid
  before   Json?
  after    Json?

  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([entity, entityId])
  @@map("audit_logs")
}

model StorageAsset {
  id        String   @id @default(uuid()) @db.Uuid
  project   Project? @relation(fields: [projectId], references: [id])
  projectId String?  @db.Uuid
  video     Video?   @relation(fields: [videoId], references: [id])
  videoId   String?  @db.Uuid

  bucket    StorageBucket
  path      String
  mimeType  String?
  sizeBytes Int?

  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([videoId])
  @@index([bucket])
  @@map("storage_assets")
}
