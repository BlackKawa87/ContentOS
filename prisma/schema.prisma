  SLIDES
  EXPORTS
  IMAGES
  DOCUMENTS
  GENERATED
  THUMBNAILS
}

enum ContentBuilderChannel {
  YOUTUBE
  SHORTS
  TIKTOK
  INSTAGRAM
  BLOG
  NEWSLETTER
