  HOOK
  SETUP
  CONTEXT
  PROBLEM
  OPEN_LOOP
  ESCALATION
  EVIDENCE
  STORY_DEVELOPMENT
  TRANSITION
  PATTERN_INTERRUPT
  REVEAL
  PAYOFF
  SUMMARY
