}

// ---------------------------------------------------------------------------
// Core / Auth
// ---------------------------------------------------------------------------

/// Mirrors a row in Supabase `auth.users`; id is the same UUID as auth.users.id.
model Profile {
  id              String   @id @db.Uuid
  email           String   @unique
  displayName     String?
  role            Role     @default(USER)
  defaultLanguage Language @default(EN)
  translationLang Language @default(PT)
  defaultVoiceId  String?
  theme           Theme    @default(LIGHT)

  openaiApiKeyEnc     Bytes?
  elevenlabsApiKeyEnc Bytes?

  reverseDefaultImportLimit Int   @default(25)
  reverseMaxVideos          Int   @default(100)
  reverseMaxPlaylists       Int   @default(10)
  outlierAboveAvgMultiplier Float @default(2)
  outlierStrongMultiplier   Float @default(5)
  outlierViralMultiplier    Float @default(10)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  projects         Project[]
  processingJobs   ProcessingJob[]   @relation("JobRetriedBy")
  apiUsageLogs     ApiUsageLog[]
  auditLogs        AuditLog[]
  viralDnaProfiles ViralDnaProfile[]

  @@index([role])
  @@map("profiles")
}

// ---------------------------------------------------------------------------
// Projects / Videos
// ---------------------------------------------------------------------------

model Project {
  id      String        @id @default(uuid()) @db.Uuid
  owner   Profile       @relation(fields: [ownerId], references: [id])
  ownerId String        @db.Uuid
  title   String
  type    ProjectType
  status  ProjectStatus @default(ACTIVE)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  videos                Video[]
  channels              Channel[]
  channelAnalyses       ChannelAnalysis[]
  contentBuilderOutputs ContentBuilderOutput[]
  knowledgeBaseEntries  KnowledgeBaseEntry[]
  apiUsageLogs          ApiUsageLog[]
  storageAssets         StorageAsset[]

  @@index([ownerId])
  @@index([status])
  @@map("projects")
}

model Video {
  id          String          @id @default(uuid()) @db.Uuid
  project     Project         @relation(fields: [projectId], references: [id])
  projectId   String          @db.Uuid
  sourceUrl   String
  sourceType  VideoSourceType
  title       String?
  durationSec Int?
  status      VideoStatus     @default(QUEUED)

  // Reverse Engineering Engine: channel-imported video metadata (all optional — unused by Study Engine)
  channel        Channel?  @relation(fields: [channelId], references: [id])
  channelId      String?   @db.Uuid
  playlist       Playlist? @relation(fields: [playlistId], references: [id])
  playlistId     String?   @db.Uuid
  youtubeVideoId String?
  thumbnailUrl   String?
  publishedAt    DateTime?
  language       String?
  tags           Json?
  chapters       Json?

  views        Int?
  likes        Int?
  comments     Int?
  viewsPerDay  Float?
  viewsPerHour Float?
  ageInDays    Int?

  outlierScore Float?
  outlierClass OutlierClass?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  processingJobs  ProcessingJob[]
  transcript      Transcript?
  translation     Translation?
  narrationAsset  NarrationAsset?
  slideDeck       SlideDeck?
  studyVideoAsset StudyVideoAsset?
  glossary        Glossary?
  quiz            Quiz?
  flashcards      Flashcard[]
  channelAnalysis ChannelAnalysis?
  storageAssets   StorageAsset[]
  apiUsageLogs    ApiUsageLog[]

  videoAnalysis     VideoAnalysis?
  videoTranscript   VideoTranscript?
  timelineSegments  TimelineSegment[]
  narrativeAnalysis NarrativeAnalysis?
  visualScenes      VisualScene[]
  audioMetric       AudioMetric?
  viralDnaProfiles  ViralDnaProfile[]

  @@index([projectId])
  @@index([status])
  @@index([channelId])
  @@index([playlistId])
  @@index([youtubeVideoId])
  @@map("videos")
}

// ---------------------------------------------------------------------------
// Reverse Engineering Engine: Channel Importer (Phase 1)
// ---------------------------------------------------------------------------

model Channel {
  id        String  @id @default(uuid()) @db.Uuid
  project   Project @relation(fields: [projectId], references: [id])
  projectId String  @db.Uuid

  sourceUrl        String
  youtubeChannelId String?
  handle           String?
  title            String?
  description      String?
  thumbnailUrl     String?
  bannerUrl        String?
  language         String?
  country          String?
  status           ChannelStatus @default(PENDING)

  createdAt  DateTime  @default(now())
  importedAt DateTime?
  lastSyncAt DateTime?
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  playlists      Playlist[]
  videos         Video[]
  processingJobs ProcessingJob[]

  @@index([projectId])
  @@map("channels")
}

model Playlist {
  id        String  @id @default(uuid()) @db.Uuid
  channel   Channel @relation(fields: [channelId], references: [id])
  channelId String  @db.Uuid

  youtubePlaylistId String
  title             String?
  description       String?
  thumbnailUrl      String?
  videoCount        Int?

  createdAt  DateTime  @default(now())
  importedAt DateTime?

  videos Video[]

  @@index([channelId])
  @@map("playlists")
}

// ---------------------------------------------------------------------------
// Processing queue
// ---------------------------------------------------------------------------

model ProcessingJob {
  id          String      @id @default(uuid()) @db.Uuid
  pipeline    JobPipeline @default(STUDY)
  video       Video?      @relation(fields: [videoId], references: [id])
  videoId     String?     @db.Uuid
  channel     Channel?    @relation(fields: [channelId], references: [id])
  channelId   String?     @db.Uuid
  stage       JobStage    @default(QUEUED)
  status      JobStatus   @default(PENDING)
  attempts    Int         @default(0)
  maxAttempts Int         @default(3)
  lastError   String?
  retriedBy   Profile?    @relation("JobRetriedBy", fields: [retriedById], references: [id])
  retriedById String?     @db.Uuid

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([videoId])
  @@index([channelId])
  @@index([stage, status])
  @@map("processing_jobs")
}

// ---------------------------------------------------------------------------
// Study Engine artifacts
// ---------------------------------------------------------------------------

model Transcript {
  id          String   @id @default(uuid()) @db.Uuid
  video       Video    @relation(fields: [videoId], references: [id])
  videoId     String   @unique @db.Uuid
  language    Language @default(EN)
  content     String
  storagePath String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("transcripts")
}

model Translation {
  id          String   @id @default(uuid()) @db.Uuid
  video       Video    @relation(fields: [videoId], references: [id])
  videoId     String   @unique @db.Uuid
  language    Language @default(PT)
  content     String
  storagePath String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("translations")
}

model NarrationAsset {
  id          String   @id @default(uuid()) @db.Uuid
  video       Video    @relation(fields: [videoId], references: [id])
  videoId     String   @unique @db.Uuid
  voiceId     String
  language    Language @default(PT)
  script      String
  storagePath String
  durationSec Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("narration_assets")
}

model SlideDeck {
  id         String  @id @default(uuid()) @db.Uuid
  video      Video   @relation(fields: [videoId], references: [id])
  videoId    String  @unique @db.Uuid
  slideCount Int
  pptxPath   String
  pdfPath    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("slide_decks")
}

model StudyVideoAsset {
  id          String @id @default(uuid()) @db.Uuid
  video       Video  @relation(fields: [videoId], references: [id])
  videoId     String @unique @db.Uuid
  storagePath String
  durationSec Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("study_video_assets")
}

model Glossary {
  id      String @id @default(uuid()) @db.Uuid
  video   Video  @relation(fields: [videoId], references: [id])
  videoId String @unique @db.Uuid
  terms   Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("glossaries")
}

model Quiz {
  id      String @id @default(uuid()) @db.Uuid
  video   Video  @relation(fields: [videoId], references: [id])
  videoId String @unique @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questions QuizQuestion[]

  @@map("quizzes")
}

model QuizQuestion {
  id            String  @id @default(uuid()) @db.Uuid
  quiz          Quiz    @relation(fields: [quizId], references: [id])
  quizId        String  @db.Uuid
  question      String
  options       Json
  correctOption Int
  explanation   String?
  order         Int     @default(0)

  createdAt DateTime @default(now())

  @@index([quizId])
  @@map("quiz_questions")
}

model Flashcard {
  id      String @id @default(uuid()) @db.Uuid
  video   Video  @relation(fields: [videoId], references: [id])
  videoId String @db.Uuid
  front   String
  back    String
  order   Int    @default(0)

  createdAt DateTime @default(now())

  @@index([videoId])
  @@map("flashcards")
}

// ---------------------------------------------------------------------------
// Reverse Engineering Engine (schema only for now)
// ---------------------------------------------------------------------------

model ChannelAnalysis {
  id        String  @id @default(uuid()) @db.Uuid
  project   Project @relation(fields: [projectId], references: [id])
  projectId String  @db.Uuid
  video     Video?  @relation(fields: [videoId], references: [id])
  videoId   String? @unique @db.Uuid

  sourceUrl String

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([projectId])
  @@map("channel_analyses")
}

// ---------------------------------------------------------------------------
// Video Reverse Engineering Engine (Phase 2): per-video analysis
// ---------------------------------------------------------------------------

/// Module 1 (download) + overall progress marker for the analysis pipeline.
/// Errors/attempts/timestamps live on ProcessingJob (reused) — not duplicated here.
model VideoAnalysis {
  id      String @id @default(uuid()) @db.Uuid
  video   Video  @relation(fields: [videoId], references: [id])
  videoId String @unique @db.Uuid

  videoStoragePath     String?
  audioStoragePath     String?
  thumbnailStoragePath String?
  subtitlesStoragePath String?
  fileSizeBytes        Int?
  downloadDurationMs   Int?
  downloadFormat       String?
  audioDurationMs      Int?

  readyForViralDnaAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("video_analyses")
}

/// Module 2: transcription.
model VideoTranscript {
  id      String @id @default(uuid()) @db.Uuid
  video   Video  @relation(fields: [videoId], references: [id])
  videoId String @unique @db.Uuid

  rawText          String
  reviewedText     String?
  language         String?
  model            String?
  inputTokens      Int?
  outputTokens     Int?
  audioMinutes     Float?
  estimatedCostUsd Float?
  wordsPerMinute   Float?
  confidence       Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  segments TranscriptSegment[]

  @@map("video_transcripts")
}

model TranscriptSegment {
  id           String          @id @default(uuid()) @db.Uuid
  transcript   VideoTranscript @relation(fields: [transcriptId], references: [id])
  transcriptId String          @db.Uuid
  index        Int
  startSec     Float
  endSec       Float
  text         String
  confidence   Float?

  @@index([transcriptId])
  @@map("transcript_segments")
}

/// Module 3: timeline segmentation into narrative blocks. User-editable.
model TimelineSegment {
  id          String              @id @default(uuid()) @db.Uuid
  video       Video               @relation(fields: [videoId], references: [id])
  videoId     String              @db.Uuid
  index       Int
  type        TimelineSegmentType
  startSec    Float
  endSec      Float
  durationSec Float
  text        String
  purpose     String?
  emotion     String?
  intensity   Float?
  confidence  Float?
  evidence    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([videoId])
  @@map("timeline_segments")
}

/// Module 4: narrative analysis conclusions, each backed by evidence text.
model NarrativeAnalysis {
  id      String @id @default(uuid()) @db.Uuid
  video   Video  @relation(fields: [videoId], references: [id])
  videoId String @unique @db.Uuid

  hookType            HookType?
  hookDurationSec     Float?
  promise             String?
  openLoopCount       Int?
  payoffCount         Int?
  revealFrequency     Float?
  storyStructure      String?
  informationDensity  Float?
  curiosityScore      Float?
  narrativeStyle      String?
  narrativePattern    NarrativePattern?
  retentionMechanisms String?
  evidence            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("narrative_analyses")
}

/// Module 5: visual analysis — one row per detected scene.
model VisualScene {
  id               String              @id @default(uuid()) @db.Uuid
  video            Video               @relation(fields: [videoId], references: [id])
  videoId          String              @db.Uuid
  index            Int
  startSec         Float
  endSec           Float
  durationSec      Float
  frameStoragePath String?
  category         VisualSceneCategory
  motion           VisualSceneMotion
  transition       String?
  sceneScore       Float?
  description      String?
  confidence       Float?

  createdAt DateTime @default(now())

  @@index([videoId])
  @@map("visual_scenes")
}

/// Module 6: deterministic audio metrics (no AI). energyCurve is the one
/// justified time-series JSON field — modeling per-sample rows would be
/// impractical for what's purely chart-rendering data.
model AudioMetric {
  id      String @id @default(uuid()) @db.Uuid
  video   Video  @relation(fields: [videoId], references: [id])
  videoId String @unique @db.Uuid

  wordsPerMinute      Float?
  averagePaceWpm      Float?
  medianPaceWpm       Float?
  pauseCount          Int?
  avgPauseDurationSec Float?
  speechDensity       Float?
  energyCurve         Json?
  volumeVariation     Float?
  silenceRatio        Float?
  narrationSpeed      Float?
  sceneSyncScore      Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("audio_metrics")
}

// ---------------------------------------------------------------------------
// Viral DNA Engine (Phase 3): synthesizes Phase 2's outputs into a versioned,
// evidence-based profile per video. One ViralDnaProfile row per version —
// `isCurrent` marks the active one; edits/regenerations create a new version
// rather than mutating history (see server/viralDnaPipeline/).
// ---------------------------------------------------------------------------

model ViralDnaProfile {
  id             String                @id @default(uuid()) @db.Uuid
  video          Video                 @relation(fields: [videoId], references: [id])
  videoId        String                @db.Uuid
  profileVersion Int
  isCurrent      Boolean               @default(true)
  status         ViralDnaProfileStatus @default(DRAFT)
  schemaVersion  String                @default("1.0.0")

  generatedAt    DateTime @default(now())
  sourceSnapshot Json? // Phase 2 tables' updatedAt values at generation time — stands in for source versioning since Phase 2 outputs aren't themselves versioned

  // Flat, queryable columns for cross-video comparison (Module 19) — kept in
  // sync with the equivalent nested JSON field below.
  primaryHookType            HookType?
  primaryNarrativePattern    NarrativePattern?
  averageWordsPerMinute      Float?
  averageSceneDurationSec    Float?
  sceneChangesPerMinute      Float?
  openLoopCount              Int?
  revealFrequency            Float?
  patternInterruptsPerMinute Float?
  textOverlayRate            Float?
  dominantMotion             VisualSceneMotion?
  dominantTransition         String?
  outlierScoreSnapshot       Float?
  overallRetentionScore      Float?
  overallConfidenceScore     Float?

  // Deep nested profiles — see docs/viral-dna-schema.md for field-level shape.
  metrics            Json? // Module 2's absolute + normalized metrics, consumed by every later stage
  hook               Json?
  narrative          Json?
  retention          Json?
  visual             Json?
  audio              Json?
  emotion            Json?
  informationDensity Json?
  performance        Json?

  warnings    Json? // string[]
  limitations Json? // string[]
  notes       String? // user-entered notes from the editing UI

  createdBy   Profile? @relation(fields: [createdById], references: [id])
  createdById String?  @db.Uuid

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  scores            ViralDnaScore[]
  hypotheses        ViralDnaHypothesis[]
  evidence          ViralDnaEvidence[]
  validationResults ViralDnaValidationResult[]

  @@unique([videoId, profileVersion])
  @@index([videoId])
  @@index([videoId, isCurrent])
  @@map("viral_dna_profiles")
}

model ViralDnaScore {
  id             String            @id @default(uuid()) @db.Uuid
  profile        ViralDnaProfile   @relation(fields: [profileId], references: [id])
  profileId      String            @db.Uuid
  scoreName      ViralDnaScoreName
  value          Float
  formulaVersion String            @default("1.0.0")
  inputs         Json?
  evidence       String?

  createdAt DateTime @default(now())

  @@unique([profileId, scoreName])
  @@index([profileId])
  @@map("viral_dna_scores")
}

model ViralDnaHypothesis {
  id                    String           @id @default(uuid()) @db.Uuid
  profile               ViralDnaProfile  @relation(fields: [profileId], references: [id])
  profileId             String           @db.Uuid
  statement             String
  supportingEvidence    Json? // string[]
  contradictingEvidence Json? // string[]
  confidence            Float?
  hypothesisType        HypothesisType
  testability           String?
  recommendedValidation String?
  status                HypothesisStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId])
  @@map("viral_dna_hypotheses")
}

model ViralDnaEvidence {
  id                String             @id @default(uuid()) @db.Uuid
  profile           ViralDnaProfile    @relation(fields: [profileId], references: [id])
  profileId         String             @db.Uuid
  evidenceId        String // stable key referenced from the nested JSON profiles, e.g. "hook.opening_sentence"
  sourceType        EvidenceSourceType
  sourceId          String? // TimelineSegment.id / VisualScene.id / TranscriptSegment.id, when applicable
  timestampStart    Float?
  timestampEnd      Float?
  transcriptExcerpt String?
  metricName        String?
  metricValue       Float?
  explanation       String?

  createdAt DateTime @default(now())

  @@index([profileId])
  @@index([profileId, evidenceId])
  @@map("viral_dna_evidence")
}

model ViralDnaValidationResult {
  id                String          @id @default(uuid()) @db.Uuid
  profile           ViralDnaProfile @relation(fields: [profileId], references: [id])
  profileId         String          @db.Uuid
  valid             Boolean
  errors            Json? // string[]
  warnings          Json? // string[]
  unsupportedClaims Json? // string[]
  missingEvidence   Json? // string[]
  confidenceSummary Json?

  createdAt DateTime @default(now())

  @@index([profileId])
  @@map("viral_dna_validation_results")
}

// ---------------------------------------------------------------------------
// Content Builder (schema only for now)
// ---------------------------------------------------------------------------

model ContentBuilderOutput {
  id        String                @id @default(uuid()) @db.Uuid
  project   Project               @relation(fields: [projectId], references: [id])
  projectId String                @db.Uuid
  channel   ContentBuilderChannel
  title     String
  content   Json
  status    ProjectStatus         @default(ACTIVE)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([projectId])
  @@map("content_builder_outputs")
}

// ---------------------------------------------------------------------------
// Knowledge Base
// ---------------------------------------------------------------------------

model KnowledgeBaseEntry {
  id        String  @id @default(uuid()) @db.Uuid
  project   Project @relation(fields: [projectId], references: [id])
  projectId String  @db.Uuid
  title     String
  entryType String
  summary   String?
  refTable  String
  refId     String  @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([refTable, refId])
  @@map("knowledge_base_entries")
}

// ---------------------------------------------------------------------------
// Observability / Cost
// ---------------------------------------------------------------------------

model ApiUsageLog {
  id        String   @id @default(uuid()) @db.Uuid
  profile   Profile  @relation(fields: [profileId], references: [id])
  profileId String   @db.Uuid
  project   Project? @relation(fields: [projectId], references: [id])
  projectId String?  @db.Uuid
  video     Video?   @relation(fields: [videoId], references: [id])
  videoId   String?  @db.Uuid

  provider         ApiProvider
  unit             String
  quantity         Float
  estimatedCostUsd Float

  createdAt DateTime @default(now())

  @@index([profileId])
  @@index([projectId])
  @@index([videoId])
  @@map("api_usage_logs")
}

model AuditLog {
  id       String   @id @default(uuid()) @db.Uuid
  actor    Profile? @relation(fields: [actorId], references: [id])
  actorId  String?  @db.Uuid
  action   String
  entity   String
  entityId String?  @db.Uuid
  before   Json?
  after    Json?

  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([entity, entityId])
  @@map("audit_logs")
}

model StorageAsset {
  id        String   @id @default(uuid()) @db.Uuid
  project   Project? @relation(fields: [projectId], references: [id])
  projectId String?  @db.Uuid
  video     Video?   @relation(fields: [videoId], references: [id])
  videoId   String?  @db.Uuid

  bucket    StorageBucket
  path      String
  mimeType  String?
  sizeBytes Int?

  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([videoId])
  @@index([bucket])
  @@map("storage_assets")
}
