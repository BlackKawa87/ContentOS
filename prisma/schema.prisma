  AUTHORITY
  PROBLEM_FIRST
  FUTURE_PROMISE
  EMOTIONAL
  SHOCKING_STATEMENT
  CURIOSITY_GAP
  VISUAL_HOOK
  RESULT_FIRST
  WARNING
  TRANSFORMATION_PROMISE
